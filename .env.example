# ============================================================
# Quantra AI — configuration. Copy to .env and fill in.
# Everything here is OPTIONAL — the app runs locally with none
# of it (file storage, console emails, billing off).
# ============================================================

# --- Core ---
PORT=5280
# Public base URL (used in verification / reset email links). In the
# cloud set this to your real domain, e.g. https://app.quantra.ai
APP_URL=http://localhost:5280
# Set to "production" in the cloud (enables Secure cookies)
NODE_ENV=

# --- AI reasoning engine (optional) ---
ANTHROPIC_API_KEY=
QUANTRA_AI_MODEL=claude-opus-4-8

# --- Live market data (optional) ---
# Crypto streams live from Binance's free public WebSocket with NO key.
# For real-time US stock quotes + live news, add a FREE Finnhub key:
#   1) sign up at https://finnhub.io  2) copy the API key  3) paste below.
# Without it, stocks/news use the existing (slower, free) Yahoo feed.
FINNHUB_API_KEY=

# --- Super-admin (optional) ---
# Comma-separated emails that may open /admin.html — an oversight panel showing
# user EMAILS + METADATA and a security AUDIT LOG. Passwords are NEVER shown
# (they are one-way scrypt hashes). Empty = nobody has admin access.
# --- CoinGecko (optional) ---
# Free "demo" key raises rate limits + works from cloud IPs (fixes the crypto
# board 429 on hosts like Render). Get one free at coingecko.com/developers.
COINGECKO_KEY=

SUPER_ADMINS=

# --- Cloud database (optional) ---
# When set, storage uses Postgres instead of local JSON files.
# Example: postgres://user:pass@host:5432/quantra
DATABASE_URL=
# Set to "disable" only for a local non-SSL Postgres
PGSSL=

# --- Email (optional; for verification + password reset) ---
# Without a key, links are printed to the server console (dev mode).
RESEND_API_KEY=
MAIL_FROM=Quantra AI <onboarding@resend.dev>

# --- Stripe billing (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ULTIMATE=

# Dev-only: simulate plan upgrades from the account menu WITHOUT Stripe.
# Auto-disabled when NODE_ENV=production. Leave blank for real Stripe testing.
QUANTRA_DEV_BILLING=

# Web Push (PWA notifications) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Premium data aggregators (optional, free tiers available)
# Financial Modeling Prep — economic/macro calendar: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=
# marketaux — multi-source premium news (Bloomberg/Reuters/CNBC headlines): https://www.marketaux.com
MARKETAUX_API_KEY=

# Twelve Data — fresher real-time global quotes incl. Gulf/Asia (free tier ~800/day): https://twelvedata.com
TWELVEDATA_API_KEY=
