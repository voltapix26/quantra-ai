{
  "name": "quantra-terminal",
  "version": "2.0.0",
  "private": true,
  "description": "Quantra AI Terminal — live technical + fundamental market analysis.",
  "scripts": {
    "start": "node server.js",
    "check": "node -e \"const cp=require('child_process');['analysis','auth','broker','globe','hero','mailer','news','onboard','plans','pwa','report','screener','server','store','sw','terminal'].forEach(f=>cp.execSync('node --check '+f+'.js',{stdio:'inherit'}));console.log('syntax: all OK')\"",
    "test:engine": "node test/engine.test.js",
    "test:smoke": "node test/smoke.test.js",
    "test": "npm run check && npm run test:engine && npm run test:smoke"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "pg": "^8.21.0",
    "stripe": "^22.2.1"
  },
  "optionalDependencies": {
    "docx": "^9.7.1",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "sharp": "^0.35.1",
    "web-push": "^3.6.7"
  }
}
